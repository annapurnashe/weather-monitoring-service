{
  "info": {
    "name": "Weather Monitoring API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Add City",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"city\": \"Mumbai\",\n  \"latitude\": 19.0760,\n  \"longitude\": 72.8777\n}"
        },
        "url": {"raw": "http://localhost:8000/cities"}
      }
    },

    {
      "name": "List Cities",
      "request": {
        "method": "GET",
        "url": {"raw": "http://localhost:8000/cities"}
      }
    },
    {
      "name": "Get Weather History",
      "request": {
        "method": "GET",
        "url": {"raw": "http://localhost:8000/cities/Mumbai/history"}
      }
    }
  ]
}




